{
    "name": "super-kernel/di",
    "description": "The di component for super-kernel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "super-kernel",
        "di",
        "container",
        "ioc"
    ],
    "homepage": "https://github.com/super-kernel/di",
    "support": {
        "issues": "https://github.com/super-kernel/di/issues",
        "source": "https://github.com/super-kernel/di"
    },
    "autoload": {
        "psr-4": {
            "SuperKernel\\Di\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperKernelTest\\Di\\": "tests/"
        }
    },
    "config": {
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "~8.4.0",
        "super-kernel/attribute": "~1.0.0",
        "super-kernel/contract": "~1.0.0"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "require-dev": {
        "super-kernel/bootstrap": "~1.0.0",
        "super-kernel/event-dispatcher": "~1.0.0",
        "super-kernel/framework": "~1.0.0"
    }
}
