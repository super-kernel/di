{
    "name": "super-kernel/di",
    "description": "The di component for super-kernel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "super-kernel",
        "di",
        "container",
        "ioc"
    ],
    "homepage": "https://github.com/super-kernel/di",
    "support": {
        "issues": "https://github.com/super-kernel/di/issues",
        "source": "https://github.com/super-kernel/di"
    },
    "autoload": {
        "psr-4": {
            "SuperKernel\\Di\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperKernelTest\\Di\\": "tests/"
        }
    },
    "config": {
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "~8.4.0",
        "super-kernel/annotator": "dev-main",
        "super-kernel/attribute": "dev-main",
        "super-kernel/contract": "dev-main"
    },
    "require-dev": {
        "super-kernel/framework": "dev-main"
    }
}
